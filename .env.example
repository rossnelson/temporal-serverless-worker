# AWS credentials
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY

# deploy.sh
ROLE_ARN=arn:aws:iam::123456789012:role/your-role-name
FUNCTION_NAME=temporal-serverless-worker
REGION=us-east-1

# setup-temporal-server.sh
TEMPORAL_DIR=/path/to/temporalio/temporal
NAMESPACE=default
IAM_ROLE_ARN=arn:aws:iam::123456789012:role/your-iam-role
LAMBDA_ARN=arn:aws:lambda:us-east-1:123456789012:function:temporal-serverless-worker
EXTERNAL_ID=your-external-id

# Worker config
TQ_NAME=worker-versioning-sample
DEPLOYMENT_NAME=my-deployment
BUILD_ID=v1

# Local paths
UI_PATH=/path/to/temporalio/ui
