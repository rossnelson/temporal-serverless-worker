# AWS credentials
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY

# AWS / Lambda
REGION=us-east-1
LAMBDA_ARN=arn:aws:lambda:us-east-1:123456789012:function:temporal-serverless-worker
IAM_ROLE_ARN=arn:aws:iam::123456789012:role/your-iam-role
EXTERNAL_ID=your-external-id
LAMBDA_ARCH=amd64

# Worker config
TQ_NAME=worker-versioning-sample
DEPLOYMENT_NAME=my-deployment
BUILD_ID=v1

# ── Staging (Temporal Cloud) ──────────────────────────────────────────────────
# Address and namespace for the target Temporal server.
# These take precedence over HOST_PORT / NAMESPACE when set.
TEMPORAL_ADDRESS=frontend.<namespace>.tmprl-test.cloud:7233
TEMPORAL_NAMESPACE=<namespace>

# mTLS client certificate and key (base64-encoded PEM).
# To encode from 1Password (macOS): echo "CERT_CONTENT" | base64
# TEMPORAL_TLS_CLIENT_CERT_BASE64 and TEMPORAL_TLS_CLIENT_KEY_BASE64 are
# required for mTLS. TEMPORAL_TLS_SERVER_ROOT_CA_CERT_BASE64 is optional.
TEMPORAL_TLS_CLIENT_CERT_BASE64=
TEMPORAL_TLS_CLIENT_KEY_BASE64=
TEMPORAL_TLS_SERVER_ROOT_CA_CERT_BASE64=

# ── Local dev (ngrok) ─────────────────────────────────────────────────────────
# Used by scripts/dev.sh when running a local Temporal server via ngrok.
TEMPORAL_DIR=/path/to/temporalio/temporal
TEMPORAL_PORT=7233
NAMESPACE=default
UI_PATH=/path/to/temporalio/ui
